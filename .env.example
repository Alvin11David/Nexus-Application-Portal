# Local development: keep this on localhost.
VITE_OTP_API_BASE="http://127.0.0.1:5055"
VITE_API_BASE_URL="http://127.0.0.1:8000"

# Production option A: if the OTP service is behind the same domain as the site,
# keep VITE_OTP_API_BASE unset and proxy /api/otp/* to the Python service.
#
# Production option B: if the OTP service is hosted separately, set it to the
# public HTTPS URL of that service, for example:
# VITE_OTP_API_BASE="https://otp.yourdomain.com"
